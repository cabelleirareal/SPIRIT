# ============================================
# SPIRIT - Environment Configuration
# ============================================

# ============================================
# LLM API KEYS
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-gemini-key-here

# ============================================
# SERVICES
# ============================================
FIRECRAWL_API_KEY=fc-your-key-here

# Supabase (optional - for production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# ============================================
# DATABASE
# ============================================
POSTGRES_PASSWORD=change-this-secure-password
REDIS_PASSWORD=change-this-secure-password

# ============================================
# SECURITY
# ============================================
JWT_SECRET=change-this-to-random-64-char-string
GRAFANA_PASSWORD=admin-password-here

# ============================================
# MESSAGING (Optional)
# ============================================
# WhatsApp - via Baileys (QR code scan)
WHATSAPP_ENABLED=true

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ENABLED=false

# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_ENABLED=false

# Discord
DISCORD_BOT_TOKEN=your-discord-token-here
DISCORD_ENABLED=false

# ============================================
# DOMAIN & SSL
# ============================================
DOMAIN=your-domain.com
ENABLE_SSL=false
LETSENCRYPT_EMAIL=your-email@example.com

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=https://your-sentry-dsn
DATADOG_API_KEY=your-datadog-key

# ============================================
# EMAIL (Optional)
# ============================================
SENDGRID_API_KEY=SG.your-key-here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# FEATURES
# ============================================
ENABLE_SIMULATION=true
ENABLE_WORKFLOWS=true
ENABLE_RAG=true
MAX_AGENTS=10
SIMULATION_DEPTH=high  # low, medium, high

# ============================================
# DEVELOPMENT
# ============================================
NODE_ENV=production
DEBUG=false
LOG_LEVEL=info  # debug, info, warn, error
